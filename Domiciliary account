from bank_account import BankAccount


class DomiciliaryAccount(BankAccount):
    EXCHANGE_RATE = 1600  # 1 USD = ₦1600

    def __init__(self, account_number, customer_name, balance_usd_cents=0):
        super().__init__(account_number, customer_name)
        self.balance = balance_usd_cents  # Balance stored in USD cents

    def deposit(self, amount_usd_cents):
        if amount_usd_cents <= 0:
            raise ValueError("Deposit amount must be greater than zero.")
        self.balance += amount_usd_cents

    def withdraw(self, amount_usd_cents):
        if amount_usd_cents <= 0:
            raise ValueError("Withdrawal amount must be greater than zero.")
        if amount_usd_cents > self.balance:
            raise ValueError("Insufficient funds.")
        self.balance -= amount_usd_cents

    def get_balance_usd(self):
        """Return balance in USD."""
        return self.balance / 100

    def convert_to_naira(self):
        """Convert USD balance to Naira."""
        return self.get_balance_usd() * self.EXCHANGE_RATE

    def display_balance(self):
        print(f"Balance (USD): ${self.get_balance_usd():.2f}")
        print(f"Balance (NGN): ₦{self.convert_to_naira():,.2f}")
